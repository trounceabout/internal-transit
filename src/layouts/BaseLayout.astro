---
// BaseLayout.astro — the HTML shell that wraps every page.
// Import global styles here so Tailwind applies everywhere.
import '@/styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The personal site of a product designer.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- RSS autodiscovery — browsers and feed readers will find this automatically -->
    <link rel="alternate" type="application/rss+xml" title="Blog RSS Feed" href="/rss.xml" />
  </head>
  <body>
    <slot />
    <!-- Vercel Speed Insights — tracks real user performance data -->
    <SpeedInsights />
  </body>
</html>
