---
// BaseLayout.astro — the HTML shell that wraps every page.
// Import global styles here so Tailwind applies everywhere.
import '@/styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

// Default description used when a page doesn't supply its own.
// Kept under 160 chars for SEO.
const { title, description = 'Cody Keisler — product designer writing about design, craft, and the work in between.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Format: "Page Title — Cody Keisler" for inner pages.
         The em-dash separator is a common SEO/UX convention for site branding. -->
    <title>{title} — Cody Keisler</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- RSS autodiscovery — browsers and feed readers will find this automatically -->
    <link rel="alternate" type="application/rss+xml" title="Blog RSS Feed" href="/rss.xml" />
  </head>
  <body>
    <slot />
    <!-- Vercel Speed Insights — tracks real user performance data -->
    <SpeedInsights />
    <!-- Vercel Analytics — tracks page views and visitor data -->
    <Analytics />
  </body>
</html>
