---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { HugeiconsIcon } from "@hugeicons/react";
import {
    UserCircleIcon,
    Note01Icon,
    Briefcase01Icon,
} from "@hugeicons/core-free-icons";
---

<BaseLayout title="Home">
    {
        /* ── Nav bar ─────────────────────────────────────────────────────────
        Full-width strip across the top. Each link has a 16px icon + label,
        matching the Sketch nav design. Icons use HugeIcons (same pattern
        as blog/index.astro). client:load is needed for React components. */
    }
    <nav class="px-6 py-4">
        <div class="max-w-4xl mx-auto flex items-center gap-6">
            <a
                href="/about"
                class="flex items-center gap-2 text-sm font-sans text-brand-ink hover:text-brand-highlight transition-colors no-underline"
            >
                <HugeiconsIcon client:load icon={UserCircleIcon} size={16} />
                about
            </a>
            <a
                href="/blog"
                class="flex items-center gap-2 text-sm font-sans text-brand-ink hover:text-brand-highlight transition-colors no-underline"
            >
                <HugeiconsIcon client:load icon={Note01Icon} size={16} />
                blog
            </a>
            <a
                href="/work"
                class="flex items-center gap-2 text-sm font-sans text-brand-ink hover:text-brand-highlight transition-colors no-underline"
            >
                <HugeiconsIcon client:load icon={Briefcase01Icon} size={16} />
                work
            </a>
        </div>
    </nav>

    {
        /* ── Main content ────────────────────────────────────────────────────
        Left-aligned, constrained to ~900px, padded from the top.
        Mirrors the Sketch layout: x:125, y:80, width:900 on a 1150px frame. */
    }
    <main class="max-w-4xl flex flex-col items-center mx-auto px-6 pt-16 pb-16">
        {
            /* Iconmark — logo.svg at 24px tall, auto width (~53px).
            Sits above the wordmark, matching the Sketch spec. */
        }
        <img
            src="/logo.svg"
            alt="Internal Transit icon"
            class="h-6 w-auto mb-4"
        />

        {
            /* Wordmark — the official SVG asset, 768×48px.
            w-full + max-w-3xl keeps it from overflowing on small screens
            while preserving the aspect ratio via h-auto. */
        }
        <h1 class="mb-4">
            <img
                src="/wordmark.svg"
                alt="Internal Transit"
                class="h-12 w-auto"
            />
        </h1>

        {/* Tagline — 14px Geist Sans, slightly muted */}
        <p class="text-sm font-mono text-brand-ink/80 mb-4">
            A place for thoughts as they make their way through my head
        </p>

        {/* Author byline — small circular avatar + name */}
        <div class="flex items-center gap-2 mb-12">
            <img
                src="/trounce.svg"
                alt="Cody Keisler"
                class="w-6 h-6 rounded-full object-cover"
            />
            <span class="text-sm font-mono font-medium text-muted-foreground">
                By Cody Keisler
            </span>
        </div>

        {
            /* Body copy — two paragraphs, max ~576px wide (max-w-xl).
            First paragraph is bold (the hook question).
            Second is regular weight (the context/story). */
        }
        <div class="max-w-2xl flex flex-col gap-4">
            <p class="text-sm font-mono font-semibold text-brand-ink leading-6">
                You ever have an idea that just gets stuck in your brain and you
                can't seem to get it out?
            </p>
            <p class="text-sm font-mono text-brand-ink/80 leading-6">
                Whether it's an opinion on your favorite movie or a need to know
                everything about how quantum mechanics works, everyone has
                thoughts that circle endlessly in their heads from time to time.
                I got tired of suffering on my own and decided "why not let
                others join in on the fun?", so Internal Transit was born.
            </p>
        </div>
    </main>
</BaseLayout>
