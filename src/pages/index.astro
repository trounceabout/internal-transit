---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    GithubLogo,
    FigmaLogo,
    LinkedinLogo,
} from "@phosphor-icons/react/dist/ssr";
---

<BaseLayout title="Work">
    {
        /* Page-level background override — this redesign uses a distinct
        portfolio palette (#FFF9F2) from the rest of the site's shared
        bg-background token, which other pages still rely on. */
    }
    <style>
        body {
            background-color: var(--color-portfolio-bg);
        }
    </style>
    {
        /* ── Nav ─────────────────────────────────────────────────────────────
        Centered, uppercase, mono. Home page now doubles as the work page
        (case studies land directly on this page later), so "Work" marks
        the current page instead of a separate "Intro" label. */
    }
    <nav class="px-6 pt-12 pb-8">
        <div class="flex items-center justify-center gap-12">
            <span
                class="text-sm font-mono font-semibold uppercase tracking-wide text-portfolio-ink"
            >
                Work
            </span>
            <a
                href="/blog"
                class="text-sm font-mono uppercase tracking-wide text-portfolio-muted hover:text-portfolio-ink transition-colors no-underline"
            >
                Blog
            </a>
        </div>
    </nav>
    <main
        class="flex flex-col items-center mx-auto px-6 pt-8 pb-24 max-w-[800px]"
    >
        <div class="flex flex-col items-center">
            <img
                src="/me-big-head.svg"
                alt="Cody Keisler"
                class="w-[200px] h-[200px] rounded-full object-cover -mb-7"
            />
            <h1
                class="font-wilco-low-end text-[40px] sm:text-[64px] leading-none mb-8 bg-clip-text text-transparent"
                style="background-image: linear-gradient(to right, #3fc6b0, #9156f7); -webkit-background-clip: text;"
            >
                Hi, I'm Cody
            </h1>
        </div>
        <div class="flex flex-col gap-4 w-full font-mono text-portfolio-ink">
            <p class="text-2xl">
                I use design to make experiences better for people.
            </p>
            <div class="flex flex-col gap-4 text-base leading-6">
                <p>
                    Bouncing between graphic design, web design, motion design,
                    and software design has taught me what design is, what it
                    isn’t, and how to use it to communicate with people.
                </p>
            </div>

            {
                /* "Find me" line — muted intro text, then three colored
                icon+name links, each brand-colored per Figma. */
            }
            <p
                class="text-base text-portfolio-muted-2 flex flex-wrap items-center gap-x-1"
            >
                Looking for me around the web? Find me on
                <a
                    href="https://github.com/trounceabout"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 font-semibold hover:underline"
                    style="color: #4183C4;"
                >
                    <GithubLogo weight="duotone" size={20} />
                    GitHub
                </a>,
                <a
                    href="https://www.figma.com/@trounceabout"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 font-semibold hover:underline"
                    style="color: #FF3737;"
                >
                    <FigmaLogo weight="duotone" size={20} />
                    Figma
                </a>, and
                <a
                    href="https://www.linkedin.com/in/codykeisler/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 font-semibold hover:underline"
                    style="color: #0077B5;"
                >
                    <LinkedinLogo weight="duotone" size={20} />
                    LinkedIn
                </a>.
            </p>
        </div>
    </main>
</BaseLayout>
