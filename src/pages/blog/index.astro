---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { HugeiconsIcon } from "@hugeicons/react";
import {
    Calendar04Icon,
    AnvilIcon,
    Brain02Icon,
    PencilRulerIcon,
    IdeaIcon,
    MaskTheater02Icon,
    Joystick03Icon,
    BrushIcon,
    CampfireIcon,
} from "@hugeicons/core-free-icons";

// Fetch all blog posts, filter out drafts, sort newest first
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

// Maps each category tag to a HugeIcon and Tailwind color classes.
// hoverText must be a complete literal string so Tailwind includes it in the build.
const categoryConfig: Record<
    string,
    { icon: any; bg: string; text: string; hoverText: string }
> = {
    design: {
        icon: PencilRulerIcon,
        bg: "bg-indigo-100",
        text: "text-indigo-700",
        hoverText: "group-hover:text-indigo-700",
    },
    philosophy: {
        icon: Brain02Icon,
        bg: "bg-purple-100",
        text: "text-purple-700",
        hoverText: "group-hover:text-purple-700",
    },
    craft: {
        icon: AnvilIcon,
        bg: "bg-orange-100",
        text: "text-orange-700",
        hoverText: "group-hover:text-orange-700",
    },
    creativity: {
        icon: IdeaIcon,
        bg: "bg-yellow-100",
        text: "text-yellow-700",
        hoverText: "group-hover:text-yellow-700",
    },
    culture: {
        icon: MaskTheater02Icon,
        bg: "bg-teal-100",
        text: "text-teal-700",
        hoverText: "group-hover:text-teal-700",
    },
    games: {
        icon: Joystick03Icon,
        bg: "bg-green-100",
        text: "text-green-700",
        hoverText: "group-hover:text-green-700",
    },
    art: {
        icon: BrushIcon,
        bg: "bg-fuchsia-100",
        text: "text-fuchsia-700",
        hoverText: "group-hover:text-fuchsia-700",
    },
    outdoors: {
        icon: CampfireIcon,
        bg: "bg-amber-100",
        text: "text-amber-700",
        hoverText: "group-hover:text-amber-700",
    },
};
---

<BaseLayout title="Blog" description="Thoughts and writing.">
    <main class="mx-auto max-w-200 px-6 py-16">
        <ul class="flex flex-col gap-12">
            {
                posts.map((post) => (
                    <li class="flex flex-col gap-3">
                        <div class="flex flex-col gap-1">
                            <a
                                href={`/blog/${post.id}`}
                                class="text-xl font-semibold text-foreground hover:text-brand-highlight hover:underline transition-colors"
                            >
                                {post.data.title}
                            </a>
                            <p class="text-md text-foreground">
                                {post.data.description}
                            </p>
                        </div>

                        {/* Date + category pills on the same row */}
                        <div class="flex items-center gap-9 flex-wrap">
                            <div class="flex items-center gap-1.5">
                                <HugeiconsIcon
                                    icon={Calendar04Icon}
                                    size={16}
                                    className="text-muted-foreground"
                                />
                                <time
                                    datetime={post.data.publishDate.toISOString()}
                                    class="text-sm font-mono text-muted-foreground"
                                >
                                    {post.data.publishDate.toLocaleDateString(
                                        "en-US",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                            </div>

                            {/* Tags: icon gets the category color, text matches and underlines on hover */}
                            <div class="flex items-center gap-3">
                                {post.data.tags.map((tag) => {
                                    const config = categoryConfig[tag];
                                    if (!config) return null;
                                    return (
                                        <span class="flex items-center gap-1.5 text-sm font-medium cursor-default group">
                                            <span class={config.text}>
                                                <HugeiconsIcon
                                                    icon={config.icon}
                                                    size={16}
                                                    color="currentColor"
                                                />
                                            </span>
                                            <span
                                                class={`font-mono text-muted-foreground group-hover:underline ${config.hoverText}`}
                                            >
                                                {tag}
                                            </span>
                                        </span>
                                    );
                                })}
                            </div>
                        </div>
                    </li>
                ))
            }
        </ul>
    </main>
</BaseLayout>
